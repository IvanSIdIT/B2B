# Client (browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server (optional — falls back to VITE_* if omitted)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Local scripts only (npm run seed:users) — never commit real value
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (server-only — set in Vercel/hosting, never commit real value)
# Enable for Production + Preview on Vercel, then Redeploy without build cache.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o
